{
  "functions": {
    "app/api/analyze/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron/daily-digest/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/earnings-reminders/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 11 * * 1-5"
    },
    {
      "path": "/api/cron/earnings-reminders",
      "schedule": "0 21 * * 1-5"
    }
  ]
}
